<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Encabezado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@android:color/white"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Registro de Cobros"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_fecha_cobro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2024-05-24"
                android:textSize="14sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- Selección de Cliente -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cliente"
                android:textSize="14sp"
                android:textColor="#666666"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/et_buscar_cliente"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:background="#F0F0F0"
                    android:hint="Buscar por nombre o clave..."
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="text"
                    android:autofillHints="name"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btn_buscar_cliente"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/boton_redondeado"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@android:color/white"
                    android:contentDescription="Buscar cliente" />
            </LinearLayout>


            <TextView
                android:id="@+id/tv_cliente_nombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Seleccione un cliente"
                android:textColor="#2196F3"
                android:textStyle="italic" />
        </LinearLayout>

        <!-- Detalles del Cobro -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Información del Pago"
                android:textSize="14sp"
                android:textColor="#666666"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forma de Pago"
                android:textSize="12sp"
                android:textColor="#888888" />

            <Spinner
                android:id="@+id/sp_forma_pago"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginBottom="12dp"
                android:background="#E0E0E0" />

            <TextView
                android:id="@+id/tv_label_banco"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Banco (Transferencia)"
                android:textSize="12sp"
                android:textColor="#888888" />

            <Spinner
                android:id="@+id/sp_banco"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginBottom="12dp"
                android:background="#E0E0E0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monto del Cobro"
                android:textSize="12sp"
                android:textColor="#888888" />

            <EditText
                android:id="@+id/et_monto_cobro"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="#F0F0F0"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:paddingStart="12dp"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Listado de Facturas (Tabla) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Facturas Pendientes"
                android:textSize="14sp"
                android:textColor="#666666"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Encabezado de Tabla -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#E0E0E0"
                android:padding="8dp">

                <CheckBox
                    android:id="@+id/cb_seleccionar_todo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Folio"
                    android:textStyle="bold"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"
                    android:text="Fecha"
                    android:textStyle="bold"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"
                    android:gravity="end"
                    android:text="Saldo"
                    android:textStyle="bold"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_facturas"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btn_aplicar_cobro_auto"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:background="@drawable/boton_redondeado"
                    android:text="Aplicar Cobro"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Seleccionado: "
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_total_seleccionado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textColor="#2196F3"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Botón de Registro -->
        <Button
            android:id="@+id/btn_registrar_cobro"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/boton_redondeado"
            android:text="💾 Registrar Cobro"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>