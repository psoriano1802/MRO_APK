<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/white">

    <EditText
        android:id="@+id/etAlmacen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:hint="Almacen Ruta 00"
        android:background="@drawable/custom_input_background"
        android:padding="10dp"
        android:textAlignment="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/etFecha"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="FECHA"
        android:padding="10dp"
        android:background="@drawable/custom_input_background"
        app:layout_constraintEnd_toStartOf="@+id/etMoneda"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etAlmacen"
        app:layout_constraintHorizontal_weight="1"/>

    <EditText
        android:id="@+id/etMoneda"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:hint="MONEDA"
        android:padding="10dp"
        android:background="@drawable/custom_input_background"
        app:layout_constraintBottom_toBottomOf="@+id/etFecha"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/etFecha"
        app:layout_constraintTop_toTopOf="@+id/etFecha"
        app:layout_constraintHorizontal_weight="1"/>

    <View
        android:id="@+id/divider1"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="12dp"
        android:background="#CCCCCC"
        app:layout_constraintTop_toBottomOf="@id/etFecha" />

    <EditText
        android:id="@+id/etCodigoCliente"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="CLIENTE"
        android:padding="10dp"
        android:background="@drawable/custom_input_background"
        app:layout_constraintEnd_toStartOf="@+id/btnBuscarCliente"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider1" />

    <Button
        android:id="@+id/btnBuscarCliente"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="BUSCAR CLIENTE"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="@+id/etCodigoCliente"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/etCodigoCliente" />

    <EditText
        android:id="@+id/etNombreCliente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="NOMBRE"
        android:padding="10dp"
        android:background="@drawable/custom_input_background"
        app:layout_constraintTop_toBottomOf="@id/etCodigoCliente" />

    <View
        android:id="@+id/divider2"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="12dp"
        android:background="#CCCCCC"
        app:layout_constraintTop_toBottomOf="@id/etNombreCliente" />

    <EditText
        android:id="@+id/etProducto"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="PRODUCTO"
        android:padding="10dp"
        android:background="@drawable/custom_input_background"
        app:layout_constraintEnd_toStartOf="@+id/btnBuscarProducto"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider2" />

    <Button
        android:id="@+id/btnBuscarProducto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="BUSCAR PRODUCTO"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="@+id/etProducto"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/etProducto" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProductos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/custom_input_background"
        app:layout_constraintBottom_toTopOf="@+id/etSubTotal"
        app:layout_constraintTop_toBottomOf="@id/etProducto" />

    <EditText
        android:id="@+id/etSubTotal"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:hint="Sub Total"
        android:background="@drawable/custom_input_background"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@+id/etIva"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etIva"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:hint="IVA"
        android:background="@drawable/custom_input_background"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@+id/etTotal"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etTotal"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Total"
        android:background="@drawable/custom_input_background"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@+id/btnAceptar"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnAceptar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="ACEPTAR"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>