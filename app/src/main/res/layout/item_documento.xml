<?xml version="1.0" encoding="utf-8"?>

<HorizontalScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:scrollbars="none"
    android:id="@+id/horizontalScroll"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:padding="6dp">

        <TextView
            android:id="@+id/tv_documento"
            android:layout_width="110dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tv_tipoOrden"
            android:layout_width="110dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tv_estatus"
            android:layout_width="90dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tv_cveActivo"
            android:layout_width="120dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tv_descripcion"
            android:layout_width="160dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tv_cvePaquete"
            android:layout_width="120dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tv_descPaquete"
            android:layout_width="160dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tv_causaMantto"
            android:layout_width="140dp"
            android:layout_height="wrap_content"/>

        <CheckBox
            android:id="@+id/ch_validar"
            android:layout_width="80dp"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/et_comentario"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:background="#F0F0F0"/>

    </LinearLayout>

</HorizontalScrollView>