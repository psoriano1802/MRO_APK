<?xml version="1.0" encoding="utf-8"?>
<HorizontalScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:scrollbars="horizontal"
    android:id="@+id/horizontalScroll"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:minHeight="80dp">

        <TextView
            android:id="@+id/tv_documento"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:maxLines="4"
            android:ellipsize="end" />

        <CheckBox
            android:id="@+id/ch_validar"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:gravity="center"/>

        <EditText
            android:id="@+id/et_comentario"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:background="#F0F0F0"
            android:minHeight="40dp"
            android:hint="Escribir comentario..."/>

        <TextView
            android:id="@+id/tv_tipoOrden"
            android:layout_width="35dp"
            android:layout_height="wrap_content"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tv_estatus"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tv_cveActivo"
            android:layout_width="100dp"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tv_descripcion"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:maxLines="4"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tv_cvePaquete"
            android:layout_width="80dp"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tv_descPaquete"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:maxLines="4"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tv_causaMantto"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:maxLines="4"
            android:ellipsize="end"/>



    </LinearLayout>

</HorizontalScrollView>